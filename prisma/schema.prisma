generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  email               String               @unique
  phone               String?              @unique
  passwordHash        String               @map("password_hash")
  role                UserRole             @default(TENANT)
  adminRole           AdminRole?           @map("admin_role")
  firstName           String               @map("first_name")
  lastName            String               @map("last_name")
  avatar              String?
  ninNumber           String?              @unique @map("nin_number")
  ninStatus           NinStatus            @default(PENDING) @map("nin_status")
  status              UserStatus           @default(ACTIVE)
  bankName            String?              @map("bank_name")
  bankAccount         String?              @map("bank_account")
  bankCode            String?              @map("bank_code")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  affiliateReferrals  AffiliateReferral[]
  commissions         Commission[]
  releasedEscrows     Escrow[]             @relation("ReleasedByAdmin")
  maintenanceRequests MaintenanceRequest[]
  receivedMessages    Message[]            @relation("ReceivedMessages")
  sentMessages        Message[]            @relation("SentMessages")
  notifications       Notification[]
  properties          Property[]           @relation("LandlordProperties")
  verifiedProperties  Property[]           @relation("VerifiedByAdmin")
  rentals             Rental[]             @relation("TenantRentals")
  scoutArea           ScoutArea[]
  scoutLeads          ScoutLead[]
  tenantProfile       TenantProfile?
  wallet              Wallet?
  referredById        Int?                 @map("referred_by_id")
  referredBy          User?                @relation("UserReferrals", fields: [referredById], references: [id])
  referredUsers       User[]               @relation("UserReferrals")
  diditSessionId      String?              @unique @map("didit_session_id")

  @@map("users")
}

model RateLimit {
  id        Int      @id @default(autoincrement())
  ip        String   // Can also be userId depending on route
  endpoint  String   // e.g., 'login', 'create_property'
  count     Int      @default(1)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([ip, endpoint])
  @@index([expiresAt])
  @@map("rate_limits")
}

model TenantProfile {
  id                        Int      @id @default(autoincrement())
  userId                    Int      @unique @map("user_id")
  employmentStatus          String   @map("employment_status")
  monthlyIncome             Decimal  @map("monthly_income") @db.Decimal(12, 2)
  employerName              String?  @map("employer_name")
  previousLandlordReference String?  @map("previous_landlord_reference") @db.Text
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tenant_profiles")
}

model Property {
  id                 String             @id @default(cuid())
  slug               String?            @unique
  landlordId         Int                @map("landlord_id")
  title              String
  description        String             @db.Text
  rentPrice          Decimal            @map("rent_price") @db.Decimal(12, 2)
  type               PropertyType
  address            String
  nearestBusStop     String?            @map("nearest_bus_stop")
  state              String             @default("Kwara")
  latitude           Decimal?           @db.Decimal(10, 8)
  longitude          Decimal?           @db.Decimal(11, 8)
  amenities          String?            @db.LongText
  status             PropertyStatus     @default(PENDING)
  verificationStatus VerificationStatus @default(UNVERIFIED) @map("verification_status")
  verifiedAt         DateTime?          @map("verified_at")
  verifiedById       Int?               @map("verified_by_id")
  scoutLeadId        Int?               @map("scout_lead_id")
  ownershipDoc       String?            @map("ownership_doc")
  studentFriendly    Boolean            @default(false) @map("student_friendly")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  featuredUntil      DateTime?          @map("featured_until")
  isFeatured         Boolean            @default(false) @map("is_featured")
  inspectionSlots    InspectionSlot[]
  landlord           User               @relation("LandlordProperties", fields: [landlordId], references: [id])
  scoutLead          ScoutLead?         @relation(fields: [scoutLeadId], references: [id])
  verifiedBy         User?              @relation("VerifiedByAdmin", fields: [verifiedById], references: [id])
  images             PropertyImage[]
  rentals            Rental[]
  city               City               @relation(fields: [cityId], references: [id])
  area               Area               @relation(fields: [areaId], references: [id])
  cityId             Int                @map("city_id")
  areaId             Int                @map("area_id")

  @@index([landlordId])
  @@index([cityId])
  @@index([areaId])
  @@index([status])
  @@index([rentPrice])
  @@index([scoutLeadId], map: "properties_scout_lead_id_fkey")
  @@index([verifiedById], map: "properties_verified_by_id_fkey")
  @@map("properties")
}

model PropertyImage {
  id         Int      @id @default(autoincrement())
  propertyId String   @map("property_id")
  url        String
  caption    String?
  isPrimary  Boolean  @default(false) @map("is_primary")
  latitude   Decimal? @db.Decimal(10, 8)
  longitude  Decimal? @db.Decimal(11, 8)
  createdAt  DateTime @default(now()) @map("created_at")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

model Rental {
  id                  Int                  @id @default(autoincrement())
  propertyId          String               @map("property_id")
  tenantId            Int                  @map("tenant_id")
  rentAmount          Decimal              @map("rent_amount") @db.Decimal(12, 2)
  serviceFee          Decimal              @map("service_fee") @db.Decimal(12, 2)
  totalPaid           Decimal              @map("total_paid") @db.Decimal(12, 2)
  startDate           DateTime             @map("start_date")
  endDate             DateTime             @map("end_date")
  status              RentalStatus         @default(PENDING)
  affiliateReferralId Int?                 @map("affiliate_referral_id")
  paystackRef         String?              @unique @map("paystack_ref")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  escrow              Escrow?
  maintenanceRequests MaintenanceRequest[]
  payments            Payment[]
  agreement           RentalAgreement?
  affiliateReferral   AffiliateReferral?   @relation(fields: [affiliateReferralId], references: [id])
  property            Property             @relation(fields: [propertyId], references: [id])
  tenant              User                 @relation("TenantRentals", fields: [tenantId], references: [id])

  @@index([propertyId])
  @@index([tenantId])
  @@index([status])
  @@index([affiliateReferralId], map: "rentals_affiliate_referral_id_fkey")
  @@map("rentals")
}

model Escrow {
  id            Int          @id @default(autoincrement())
  rentalId      Int          @unique @map("rental_id")
  amount        Decimal      @db.Decimal(12, 2)
  status        EscrowStatus @default(PENDING)
  releasedAt    DateTime?    @map("released_at")
  releasedById  Int?         @map("released_by_id")
  disputeReason String?      @map("dispute_reason") @db.Text
  autoReleaseAt DateTime?    @map("auto_release_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  commissions   Commission[]
  releasedBy    User?        @relation("ReleasedByAdmin", fields: [releasedById], references: [id])
  rental        Rental       @relation(fields: [rentalId], references: [id])

  @@index([releasedById], map: "escrows_released_by_id_fkey")
  @@map("escrows")
}

model Payment {
  id          Int           @id @default(autoincrement())
  rentalId    Int           @map("rental_id")
  amount      Decimal       @db.Decimal(12, 2)
  paystackRef String?       @unique @map("paystack_ref")
  nombaRef    String?       @unique @map("nomba_ref")
  status      PaymentStatus @default(PENDING)
  paidAt      DateTime?     @map("paid_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  rental      Rental        @relation(fields: [rentalId], references: [id])

  @@index([rentalId])
  @@map("payments")
}

model Commission {
  id         Int              @id @default(autoincrement())
  escrowId   Int              @map("escrow_id")
  userId     Int              @map("user_id")
  type       CommissionType
  amount     Decimal          @db.Decimal(12, 2)
  percentage Decimal          @db.Decimal(5, 2)
  status     CommissionStatus @default(PENDING)
  expiresAt  DateTime?        @map("expires_at")
  paidAt     DateTime?        @map("paid_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  escrow     Escrow           @relation(fields: [escrowId], references: [id])
  user       User             @relation(fields: [userId], references: [id])

  @@index([escrowId])
  @@index([userId])
  @@map("commissions")
}

model ScoutLead {
  id              Int          @id @default(autoincrement())
  scoutId         Int          @map("scout_id")
  landlordName    String       @map("landlord_name")
  landlordPhone   String       @map("landlord_phone")
  propertyAddress String       @map("property_address")
  areaId          Int          @map("area_id")
  notes           String?      @db.Text
  status          LeadStatus   @default(SUBMITTED)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  latitude        Decimal?     @db.Decimal(10, 8)
  longitude       Decimal?     @db.Decimal(11, 8)
  properties      Property[]
  scout           User         @relation(fields: [scoutId], references: [id])
  area            Area         @relation(fields: [areaId], references: [id])

  @@index([scoutId])
  @@index([areaId])
  @@map("scout_leads")
}

model ScoutArea {
  id     Int  @id @default(autoincrement())
  userId Int  @map("user_id")
  areaId Int  @map("area_id")
  user   User @relation(fields: [userId], references: [id])
  area   Area @relation(fields: [areaId], references: [id])

  @@unique([userId, areaId])
  @@map("scout_areas")
}

model City {
  id         Int        @id @default(autoincrement())
  name       String     @unique
  state      String
  latitude   Decimal?   @db.Decimal(10, 8)
  longitude  Decimal?   @db.Decimal(11, 8)
  areas      Area[]
  properties Property[]

  @@map("cities")
}

model Area {
  id         Int         @id @default(autoincrement())
  name       String
  cityId     Int         @map("city_id")
  latitude   Decimal?    @db.Decimal(10, 8)
  longitude  Decimal?    @db.Decimal(11, 8)
  city       City        @relation(fields: [cityId], references: [id])
  properties Property[]
  scoutAreas ScoutArea[]
  scoutLeads ScoutLead[]

  @@unique([name, cityId])
  @@map("areas")
}

model AffiliateReferral {
  id           Int      @id @default(autoincrement())
  affiliateId  Int      @map("affiliate_id")
  referralCode String   @unique @map("referral_code")
  clicks       Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  affiliate    User     @relation(fields: [affiliateId], references: [id])
  rentals      Rental[]

  @@index([affiliateId])
  @@map("affiliate_referrals")
}

model InspectionSlot {
  id         Int              @id @default(autoincrement())
  propertyId String           @map("property_id")
  date       DateTime
  startTime  String           @map("start_time")
  endTime    String           @map("end_time")
  status     InspectionStatus @default(AVAILABLE)
  bookedById Int?             @map("booked_by_id")
  createdAt  DateTime         @default(now()) @map("created_at")
  property   Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([date])
  @@map("inspection_slots")
}

model RentalAgreement {
  id               Int       @id @default(autoincrement())
  rentalId         Int       @unique @map("rental_id")
  documentUrl      String?   @map("document_url")
  tenantSignature   String?   @db.Text @map("tenant_signature")
  landlordSignature String?   @db.Text @map("landlord_signature")
  tenantSigned       Boolean   @default(false) @map("tenant_signed")
  landlordSigned     Boolean   @default(false) @map("landlord_signed")
  tenantSignedAt     DateTime? @map("tenant_signed_at")
  landlordSignedAt   DateTime? @map("landlord_signed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  rental             Rental    @relation(fields: [rentalId], references: [id])

  @@map("rental_agreements")
}

model MaintenanceRequest {
  id          Int               @id @default(autoincrement())
  rentalId    Int               @map("rental_id")
  tenantId    Int               @map("tenant_id")
  category    String
  title       String
  description String            @db.Text
  images      String?           @db.LongText
  status      MaintenanceStatus @default(SUBMITTED)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  rental      Rental            @relation(fields: [rentalId], references: [id])
  tenant      User              @relation(fields: [tenantId], references: [id])

  @@index([rentalId])
  @@index([tenantId])
  @@map("maintenance_requests")
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int      @map("sender_id")
  receiverId Int      @map("receiver_id")
  rentalId   Int?     @map("rental_id")
  content    String   @db.Text
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([rentalId])
  @@map("messages")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  link      String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Wallet {
  id                 Int                 @id @default(autoincrement())
  userId             Int                 @unique @map("user_id")
  balance            Decimal             @default(0.00) @db.Decimal(12, 2)
  totalEarned        Decimal             @default(0.00) @map("total_earned") @db.Decimal(12, 2)
  totalWithdrawn     Decimal             @default(0.00) @map("total_withdrawn") @db.Decimal(12, 2)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  transactions       Transaction[]
  user               User                @relation(fields: [userId], references: [id])
  withdrawalRequests WithdrawalRequest[]

  @@map("wallets")
}

model Transaction {
  id            Int             @id @default(autoincrement())
  walletId      Int             @map("wallet_id")
  amount        Decimal         @db.Decimal(12, 2)
  type          TransactionType
  description   String?
  referenceId   String?         @map("reference_id")
  referenceType String?         @map("reference_type")
  createdAt     DateTime        @default(now()) @map("created_at")
  wallet        Wallet          @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([type])
  @@map("transactions")
}

model WithdrawalRequest {
  id            Int              @id @default(autoincrement())
  walletId      Int              @map("wallet_id")
  amount        Decimal          @db.Decimal(12, 2)
  status        WithdrawalStatus @default(PENDING)
  bankName      String           @map("bank_name")
  bankAccount   String           @map("bank_account")
  bankCode      String?          @map("bank_code")
  processedAt   DateTime?        @map("processed_at")
  processedById Int?             @map("processed_by_id")
  adminNotes    String?          @map("admin_notes") @db.Text
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  wallet        Wallet           @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([status])
  @@map("withdrawal_requests")
}

model PlatformSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string")
  label       String
  group       String
  description String?  @db.Text
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

enum UserRole {
  TENANT
  LANDLORD
  SCOUT
  AFFILIATE
  ADMIN
}

enum AdminRole {
  SUPER_ADMIN
  VERIFICATION_OFFICER
  SUPPORT
}

enum NinStatus {
  PENDING
  VERIFIED
  FAILED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BLACKLISTED
}

enum PropertyType {
  SELF_CON
  SINGLE_ROOM
  FLAT
  TWO_BEDROOM
  THREE_BEDROOM
}

enum PropertyStatus {
  PENDING
  VERIFIED
  RENTED
  INACTIVE
}

enum VerificationStatus {
  UNVERIFIED
  IN_PROGRESS
  VERIFIED
  REJECTED
  SUSPICIOUS
}

enum RentalStatus {
  PENDING
  ACTIVE
  COMPLETED
  DISPUTED
  CANCELLED
}

enum EscrowStatus {
  PENDING
  HELD
  RELEASED
  DISPUTED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum CommissionType {
  SCOUT
  AFFILIATE
  PLATFORM
}

enum CommissionStatus {
  PENDING
  PAID
  CANCELLED
}

enum LeadStatus {
  SUBMITTED
  REVIEWING
  APPROVED
  REJECTED
}

enum InspectionStatus {
  AVAILABLE
  BOOKED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  SUBMITTED
  IN_PROGRESS
  RESOLVED
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSED
  FAILED
  REJECTED
}
